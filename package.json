{
  "name": "shopping-list-dashboard",
  "version": "1.0.0",
  "homepage": "https://diogocavilha.github.io/lista-compras-gh-pages",
  "description": "Shopping list management app with time-tracking analytics for supermarket trips",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
