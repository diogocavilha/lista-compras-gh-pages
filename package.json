    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "gh-pages": "^6.3.0",
    "terser": "^5.46.1",
    "typescript": "^5.1.6",
    "vite": "^5.0.0"
  }
}
